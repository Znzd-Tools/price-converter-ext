{
  "name": "price-converter-ext",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Chrome extension to convert prices on any webpage",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc -b && vite build && vite build --config vite.content.config.ts",
    "typecheck": "tsc -b"
  },
  "packageManager": "pnpm@10.18.2",
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
